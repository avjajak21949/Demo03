@model dynamic

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 text-center text-lg-start">
                <h1 class="display-4 fw-bold mb-4">Transform Your School Management</h1>
                <p class="lead text-muted mb-4">Streamline student records, class schedules, and teacher management with our all-in-one platform designed to save time and reduce paperwork.</p>
                <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3">
                    <a href="#" class="btn btn-primary btn-lg px-4 me-sm-2">Start Free Trial</a>
                    <a href="#" class="btn btn-outline-secondary btn-lg px-4">Watch Demo</a>
                </div>
                <div class="d-flex align-items-center justify-content-center justify-content-lg-start mt-4">
                    <div class="d-flex">
                        <img src="https://via.placeholder.com/40" class="rounded-circle border border-2 border-white" alt="User" style="margin-right: -10px;">
                        <img src="https://via.placeholder.com/40" class="rounded-circle border border-2 border-white" alt="User" style="margin-right: -10px;">
                        <img src="https://via.placeholder.com/40" class="rounded-circle border border-2 border-white" alt="User">
                    </div>
                    <div class="ms-3">
                        <p class="mb-0 small text-muted">Trusted by 500+ schools worldwide</p>
                        <div class="text-warning">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                            <span class="text-dark ms-1">4.8/5</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-img position-relative p-4 bg-light rounded-3 shadow">
                    <img src="https://via.placeholder.com/600x400" alt="Dashboard Preview" class="img-fluid rounded-2 shadow-sm">
                    <div class="position-absolute top-0 start-0 bg-primary text-white px-3 py-1 rounded-end">New Feature</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="badge bg-primary-soft text-primary mb-3">Everything you need</span>
            <h2 class="fw-bold mb-3">Comprehensive School Management</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Our platform provides all the tools you need to efficiently manage your educational institution.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="h4">Student Management</h3>
                    <p class="text-muted">Track student attendance, grades, and personal information with our intuitive interface.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-chalkboard-teacher"></i>
                    </div>
                    <h3 class="h4">Teacher Portal</h3>
                    <p class="text-muted">Empower teachers with tools for class management, assignments, and student communication.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <h3 class="h4">Class Scheduling</h3>
                    <p class="text-muted">Create conflict-free schedules with our drag-and-drop interface and automatic optimization.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-file-invoice-dollar"></i>
                    </div>
                    <h3 class="h4">Billing & Finance</h3>
                    <p class="text-muted">Automate tuition collection, generate invoices, and track payments seamlessly.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3 class="h4">Analytics & Reports</h3>
                    <p class="text-muted">Gain insights with customizable reports and real-time dashboards.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="feature-card p-4 h-100 bg-white rounded-3 shadow-sm">
                    <div class="feature-icon bg-primary-soft text-primary rounded-circle mb-3" style="width: 50px; height: 50px; line-height: 50px; text-align: center;">
                        <i class="fas fa-comments"></i>
                    </div>
                    <h3 class="h4">Parent Communication</h3>
                    <p class="text-muted">Keep parents informed with automated notifications and messaging.</p>
                    <a href="#" class="text-primary text-decoration-none">Learn more <i class="fas fa-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

